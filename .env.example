# ─── Variables Docker Compose ─────────────────────────────────────────────
# Copier ce fichier en .env et remplir les valeurs avant docker compose up

# PostgreSQL — utilisateur applicatif
DB_PASSWORD=CHANGE_ME_min16chars

# PostgreSQL — utilisateurs supplémentaires (init uniquement)
DB_MIGRATE_PASSWORD=CHANGE_ME_min16chars
DB_READONLY_PASSWORD=CHANGE_ME_min16chars

# Redis
REDIS_PASSWORD=CHANGE_ME_min16chars

# MinIO
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME_min8chars
