{
  "name": "selene-backend",
  "version": "0.1.0",
  "description": "Séléné — Backend NestJS + Fastify",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug 0.0.0.0:9229 --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:run": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli migration:run --dataSource src/config/data-source.ts",
    "migration:revert": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli migration:revert --dataSource src/config/data-source.ts",
    "migration:generate": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli migration:generate --dataSource src/config/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/swagger": "^8.0.0",
    "typeorm": "^0.3.20",
    "pg": "^8.11.0",
    "ioredis": "^5.3.2",
    "socket.io": "^4.7.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "bcrypt": "^5.1.1",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "zod": "^3.23.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "twilio": "^5.0.0",
    "firebase-admin": "^12.0.0",
    "openai": "^4.0.0",
    "@fastify/multipart": "^8.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^20.12.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/pg": "^8.11.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@auth/(.*)$": "<rootDir>/auth/$1",
      "^@users/(.*)$": "<rootDir>/users/$1",
      "^@activities/(.*)$": "<rootDir>/activities/$1",
      "^@matching/(.*)$": "<rootDir>/matching/$1",
      "^@chat/(.*)$": "<rootDir>/chat/$1",
      "^@notifications/(.*)$": "<rootDir>/notifications/$1",
      "^@geo/(.*)$": "<rootDir>/geo/$1",
      "^@moderation/(.*)$": "<rootDir>/moderation/$1",
      "^@adapters/(.*)$": "<rootDir>/adapters/$1",
      "^@config/(.*)$": "<rootDir>/config/$1"
    },
    "collectCoverageFrom": [
      "**/*.service.ts",
      "**/*.guard.ts",
      "**/*.pipe.ts",
      "**/*.strategy.ts",
      "!**/*.module.ts",
      "!**/main.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
