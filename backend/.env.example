# ─── Application ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://selene_app:CHANGE_ME@db:5432/selene_db
DB_PASSWORD=CHANGE_ME_min16chars

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_PASSWORD=CHANGE_ME_min16chars

# ─── JWT (RS256) ──────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# ─── Drivers (Pattern Adapter) ────────────────────────────────────────────
STORAGE_DRIVER=minio
MAP_DRIVER=maplibre
OTP_DRIVER=mock
PUSH_DRIVER=mock
MODERATION_DRIVER=mock
ROUTING_DRIVER=osrm

# ─── MinIO (dev) ──────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME_min8chars
MINIO_BUCKET=selene-dev

# ─── Cloudflare R2 (prod) ─────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=selene-prod
R2_PUBLIC_DOMAIN=

# ─── Mapbox ───────────────────────────────────────────────────────────────
MAPBOX_TOKEN=

# ─── OSRM (dev) ───────────────────────────────────────────────────────────
OSRM_URL=http://osrm:5000

# ─── Twilio OTP (staging/prod) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── FCM Android ──────────────────────────────────────────────────────────
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# ─── APNs iOS ─────────────────────────────────────────────────────────────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY_PATH=

# ─── OpenAI (modération prod) ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_ORG_ID=
